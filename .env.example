# ============================================================
#  ForgeIQ — Metallurgy Platform — Environment Settings
# ============================================================
# Copy this file to `.env` (same folder) and adjust the values.
# Used by docker-compose (.config/docker-compose.yml).
#
# For non-Docker (pnpm/npm) frontend, copy `frontend/.env.example`
# to `frontend/.env.local` instead.

# --- MongoDB ---
# Atlas example: mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/?retryWrites=true&w=majority
# Local example: mongodb://localhost:27017
DB_URI=mongodb://localhost:27017
DB_NAME=forgeiq

# --- Session ---
# MUST be at least 32 characters. Generate a fresh one for production!
# Quick generator (PowerShell):
#   -join ((33..126) | Get-Random -Count 48 | % {[char]$_})
SESSION_PASSWORD=CHANGE_ME_to_a_random_string_of_at_least_32_chars
SESSION_COOKIE_NAME=forgeiq_session

# --- Public backend URLs (visible to browser) ---
# When using Docker on the same machine, leave as localhost.
# For LAN/remote access, replace with the host IP or domain.
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_BACKEND2_URL=http://localhost:5001

# --- Ports ---
FRONTEND_PORT=3000
BACKEND1_PORT=5000
BACKEND2_PORT=5001

# --- Logging ---
LOG_LEVEL=INFO
